---
import { chatLog } from '../data/chat-log';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Geminiとの対話録</title>
  </head>
  <body>
    <div class="chat-container">
      
      {chatLog.map((message) => (
        <div class={`message ${message.role}-message`}>
          {message.role === 'user' ? (
            <div class="bubble">{message.text}</div>
          ) : (
            <div class="plain-text">{message.text}</div>
          )}
        </div>
      ))}

    </div>
  </body>
</html>

<style>
  /* スタイル（CSS）は先ほどと全く同じなので省略せずにそのまま残しておいてください */
  body {
    background-color: #131314;
    color: #e3e3e3;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
  }
  .chat-container {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .message {
    display: flex;
    width: 100%;
  }
  .user-message {
    justify-content: flex-end;
  }
  .bubble {
    background-color: #2f2f30;
    color: #e3e3e3;
    padding: 14px 20px;
    border-radius: 22px;
    max-width: 75%;
    line-height: 1.6;
    font-size: 15px;
    word-break: break-word;
  }
  .gemini-message {
    justify-content: flex-start;
  }
  .plain-text {
    color: #e3e3e3;
    max-width: 85%;
    line-height: 1.75;
    font-size: 16px;
    padding: 4px 0;
  }
</style>